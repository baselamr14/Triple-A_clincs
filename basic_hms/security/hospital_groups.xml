<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_clinic_permissions" model="ir.module.category">
            <field name="name">Clinic Permissions</field>
            <field name="description">Access rights for clinic users</field>
            <field name="sequence">30</field>
        </record>

        <record id="bi_group_doctor" model="res.groups">
            <field name="name">Doctor</field>
            <field name="comment">The user will have access to doctor-related data.</field>
            <field name="category_id" ref="basic_hms.module_category_clinic_permissions"/>
        </record>

        <record id="group_chemist" model="res.groups">
            <field name="name">Chemist</field>
            <field name="comment">The user will have access to chemist-related data.</field>
            <field name="category_id" ref="basic_hms.module_category_clinic_permissions"/>
        </record>

        <record id="group_medical_group" model="res.groups">
            <field name="name">Medical Group</field>
            <field name="comment">The user will have access to medical group-related data.</field>
            <field name="category_id" ref="basic_hms.module_category_clinic_permissions"/>
        </record>

        <record id="group_receptionist" model="res.groups">
            <field name="name">Receptionist</field>
            <field name="comment">The user will have access to receptionist-related data.</field>
            <field name="category_id" ref="basic_hms.module_category_clinic_permissions"/>
        </record>

    </data>
</odoo>
